[Unit]
Description=Pachca AI Agent
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/pachca-ai-agent
EnvironmentFile=/etc/pachca-ai-agent.env
ExecStart=/opt/pachca-ai-agent/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
